rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: conversations
    // Document ID: {conversationId}
    // Fields:
    //   - id: string (required)
    //   - createdAt: timestamp (required)
    //   - participants: list of strings (required)
    //
    // Collection: conversations/{conversationId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - id: string (required)
    //   - conversationId: string (required)
    //   - senderId: string (required)
    //   - text: string (required)
    //   - translatedText: string (optional)
    //   - language: string (required, 'en' or 'te')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isParticipant(conversationId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'conversationId', 'senderId', 'text', 'language', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.language in ['en', 'te'] &&
             data.senderId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && isParticipant(conversationId);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && isParticipant(conversationId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && isParticipant(conversationId);
        allow create: if isAuthenticated() && isParticipant(conversationId) && isValidMessage(request.resource.data);
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
